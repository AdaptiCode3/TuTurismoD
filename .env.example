# ==============================================================================
# TU-TURISMO BACKEND — Plantilla de Variables de Entorno
# ==============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores reales en .env
#   3. NUNCA cometas el archivo .env al repositorio (está en .gitignore)
# ==============================================================================

# --- Django Core ---
SECRET_KEY=cambia-esta-clave-secreta-por-una-muy-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- MongoDB Atlas ---
# Copia la cadena de conexión desde: Atlas → tu cluster → Connect → Drivers → Python
# Sustituye <usuario>, <password> y <cluster> con tus credenciales reales.
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=TuTurismo
MONGO_DB_NAME=tuturismo_db

# --- CORS ---
# Orígenes permitidos separados por coma (sin espacios)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
